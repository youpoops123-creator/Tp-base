-- ⚙️ HELPER
local Helper = Win:CreateTab("Helper", 4483362458)

Helper:CreateToggle({
    Name = "ESP",
    Callback = function(v)
        _G.ESP = v
        while _G.ESP do
            task.wait(1)
            for _,plr in pairs(game.Players:GetPlayers()) do
                if plr ~= game.Players.LocalPlayer and plr.Character then
                    if not plr.Character:FindFirstChild("ESP") then
                        local bill = Instance.new("BillboardGui", plr.Character)
                        bill.Name = "ESP"
                        bill.Size = UDim2.new(0,200,0,50)
                        bill.AlwaysOnTop = true

                        local txt = Instance.new("TextLabel", bill)
                        txt.Size = UDim2.new(1,0,1,0)
                        txt.BackgroundTransparency = 1
                        txt.TextColor3 = Color3.new(1,0,0)
                        txt.TextScaled = true
                        txt.Text = plr.DisplayName.."(@"..plr.Name..")"
                    end
                end
            end
        end
    end
})

Helper:CreateButton({
    Name = "TP Player",
    Callback = function()
        local g = Instance.new("ScreenGui", game.CoreGui)
        local f = Instance.new("Frame", g)
        f.Size = UDim2.new(0,200,0,300)
        f.Position = UDim2.new(0,50,0.5,-150)

        for i,p in pairs(game.Players:GetPlayers()) do
            local b = Instance.new("TextButton", f)
            b.Size = UDim2.new(1,0,0,30)
            b.Position = UDim2.new(0,0,0,(i-1)*30)
            b.Text = p.Name

            b.MouseButton1Click:Connect(function()
                game.Players.LocalPlayer.Character:MoveTo(p.Character.HumanoidRootPart.Position)
            end)
        end
    end
})

