-- STEALER
-- =====================

button(pages["Stealer"],"Steal Floor UI",function()
_G.floor = not _G.floor

if _G.floor then
local b = Instance.new("TextButton", gui)
b.Size = UDim2.new(0,130,0,40)
b.Position = UDim2.new(1,-140,0.5,0)
b.Text = "Steal Floor ON"
_G.floorUI = b
else
if _G.floorUI then _G.floorUI:Destroy() end
end

end,10)

button(pages["Stealer"],"Anti Ragdoll",function()
if player.Character then
for _,v in pairs(player.Character:GetDescendants()) do
if v:IsA("BallSocketConstraint") then
v:Destroy()
end
end
end
end,60)

