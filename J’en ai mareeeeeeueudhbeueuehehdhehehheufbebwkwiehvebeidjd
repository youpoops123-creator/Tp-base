repeat task.wait() until game:IsLoaded()

local player = game.Players.LocalPlayer
local gui = Instance.new("ScreenGui", game.CoreGui)

-- KEY
local KEY = "Jaimepasarbi-2026"

local keyFrame = Instance.new("Frame", gui)
keyFrame.Size = UDim2.new(0,300,0,150)
keyFrame.Position = UDim2.new(0.5,-150,0.5,-75)
keyFrame.BackgroundColor3 = Color3.fromRGB(0,0,0)

local box = Instance.new("TextBox", keyFrame)
box.Size = UDim2.new(1,0,0.5,0)
box.PlaceholderText = "Enter Key"

local btn = Instance.new("TextButton", keyFrame)
btn.Size = UDim2.new(1,0,0.5,0)
btn.Position = UDim2.new(0,0,0.5,0)
btn.Text = "ENTER"

function loadHub()
keyFrame:Destroy()

-- Loading
local load = Instance.new("TextLabel", gui)
load.Size = UDim2.new(1,0,1,0)
load.BackgroundColor3 = Color3.fromRGB(0,0,0)
load.Text = "JAIMEPASARBI HUB"
load.TextScaled = true
load.TextColor3 = Color3.fromRGB(255,0,0)
task.wait(2)
load:Destroy()

-- Toggle
local toggle = Instance.new("TextButton", gui)
toggle.Size = UDim2.new(0,60,0,60)
toggle.Position = UDim2.new(0,10,0.5,-30)
toggle.Text = "JPA"
toggle.BackgroundColor3 = Color3.fromRGB(180,0,0)
toggle.Draggable = true

-- Main
local main = Instance.new("Frame", gui)
main.Size = UDim2.new(0,520,0,320)
main.Position = UDim2.new(0.5,-260,0.5,-160)
main.BackgroundColor3 = Color3.fromRGB(0,0,0)
main.Visible = false
main.Active = true
main.Draggable = true

toggle.MouseButton1Click:Connect(function()
main.Visible = not main.Visible
end)

local title = Instance.new("TextLabel", main)
title.Size = UDim2.new(1,0,0,40)
title.Text = "JAIMEPASARBI HUB"
title.TextScaled = true
title.BackgroundTransparency = 1
title.TextColor3 = Color3.new(1,1,1)

-- Tabs
local pages = {}
local function createPage(name)
local f = Instance.new("Frame", main)
f.Size = UDim2.new(1,0,1,-90)
f.Position = UDim2.new(0,0,0,90)
f.Visible = false
f.BackgroundTransparency = 1
pages[name] = f
end

local tabs = {"Stealer","Helper","Player","Finder","Server","Discord"}

for i,name in pairs(tabs) do
local b = Instance.new("TextButton", main)
b.Size = UDim2.new(0,85,0,30)
b.Position = UDim2.new(0,(i-1)*85,0,45)
b.Text = name

createPage(name)

b.MouseButton1Click:Connect(function()
for _,p in pairs(pages) do p.Visible = false end
pages[name].Visible = true
end)
end

local function button(parent,text,callback,y)
local b = Instance.new("TextButton", parent)
b.Size = UDim2.new(0,220,0,35)
b.Position = UDim2.new(0,10,0,y)
b.Text = text
b.MouseButton1Click:Connect(callback)
end

