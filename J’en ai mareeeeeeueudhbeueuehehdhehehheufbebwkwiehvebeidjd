-- PLAYER
-- =====================

button(pages["Player"],"Infinite Jump",function()
_G.jump = not _G.jump
game:GetService("UserInputService").JumpRequest:Connect(function()
if _G.jump then
player.Character:FindFirstChildOfClass("Humanoid"):ChangeState("Jumping")
end
end)
end,10)

button(pages["Player"],"Speed Boost",function()
player.Character.Humanoid.WalkSpeed = 50
end,60)

button(pages["Player"],"Jump Boost",function()
player.Character.Humanoid.JumpPower = 100
end,110)

-- =====================
-- FINDER PRO
-- =====================

button(pages["Finder"],"Open Finder PRO",function()

local HttpService = game:GetService("HttpService")
local TeleportService = game:GetService("TeleportService")

local fgui = Instance.new("ScreenGui", game.CoreGui)

local frame = Instance.new("Frame", fgui)
frame.Size = UDim2.new(0,380,0,320)
frame.Position = UDim2.new(0.5,-190,0.5,-160)
frame.BackgroundColor3 = Color3.fromRGB(0,0,0)

local title = Instance.new("TextLabel", frame)
title.Size = UDim2.new(1,0,0,40)
title.Text = "FINDER PRO"
title.TextScaled = true
title.BackgroundTransparency = 1

local data = HttpService:JSONDecode(game:HttpGet(
"https://games.roblox.com/v1/games/"..game.PlaceId.."/servers/Public?sortOrder=Desc&limit=100"
))

local y = 0
for _,s in pairs(data.data) do
if s.id ~= game.JobId then
y += 1
if y > 6 then break end

local txt = Instance.new("TextLabel", frame)
txt.Size = UDim2.new(0.6,0,0,30)
txt.Position = UDim2.new(0.05,0,0.15 + y*0.1,0)
txt.Text = "👥 "..s.playing.."/"..s.maxPlayers
txt.BackgroundTransparency = 1

local btn = Instance.new("TextButton", frame)
btn.Size = UDim2.new(0.25,0,0,30)
btn.Position = UDim2.new(0.7,0,0.15 + y*0.1,0)
btn.Text = "JOIN"

btn.MouseButton1Click:Connect(function()
TeleportService:TeleportToPlaceInstance(game.PlaceId, s.id, player)
end)
end
end

end,10)

-- =====================
-- SERVER HOPPER
-- =====================

button(pages["Server"],"Server Hop",function()

local HttpService = game:GetService("HttpService")
local TeleportService = game:GetService("TeleportService")

local data = HttpService:JSONDecode(game:HttpGet(
"https://games.roblox.com/v1/games/"..game.PlaceId.."/servers/Public?sortOrder=Desc&limit=100"
))

for _,s in pairs(data.data) do
if s.playing < s.maxPlayers then
TeleportService:TeleportToPlaceInstance(game.PlaceId, s.id, player)
break
end
end

end,10)

