-- TAB SYSTEM
local tabs = {}

local function createTab(name, posX)
    local btn = Instance.new("TextButton", frame)
    btn.Size = UDim2.new(0.3,0,0,30)
    btn.Position = UDim2.new(posX,0,0.12,0)
    btn.Text = name
    btn.BackgroundColor3 = Color3.fromRGB(150,0,0)
    btn.TextScaled = true
    btn.Font = Enum.Font.Cartoon
    Instance.new("UICorner", btn)

    local tabFrame = Instance.new("Frame", frame)
    tabFrame.Size = UDim2.new(1,0,0.7,0)
    tabFrame.Position = UDim2.new(0,0,0.22,0)
    tabFrame.BackgroundTransparency = 1
    tabFrame.Visible = false

    btn.MouseButton1Click:Connect(function()
        for _,t in pairs(tabs) do
            t.Visible = false
        end
        tabFrame.Visible = true
    end)

    table.insert(tabs, tabFrame)
    return tabFrame
end

local mainTab = createTab("MAIN", 0)
local playerTab = createTab("PLAYER", 0.33)
local finderTab = createTab("FINDER", 0.66)

tabs[1].Visible = true

-- BUTTON CREATOR
local function createButton(parent, text, y, func)
    local btn = Instance.new("TextButton", parent)
    btn.Size = UDim2.new(0.8,0,0,35)
    btn.Position = UDim2.new(0.1,0,y,0)
    btn.Text = text
    btn.BackgroundColor3 = Color3.fromRGB(180,0,0)
    btn.TextScaled = true
    btn.Font = Enum.Font.Cartoon
    Instance.new("UICorner", btn)
    btn.MouseButton1Click:Connect(func)
end

-- SERVER HOP
local autoHop = false

local function hop()
    local data = HttpService:JSONDecode(game:HttpGet(
        "https://games.roblox.com/v1/games/"..PlaceID.."/servers/Public?sortOrder=Desc&limit=100"
    ))

    for _,s in pairs(data.data) do
        if s.id ~= JobID and s.playing >= s.maxPlayers - 2 then
            TeleportService:TeleportToPlaceInstance(PlaceID, s.id, player)
            break
        end
    end
end

task.spawn(function()
    while true do
        if autoHop then hop() end
        task.wait(10)
    end
end)

-- ESP
local espOn = false
local espObjs = {}

local function toggleESP()
    espOn = not espOn

    for _,v in pairs(espObjs) do
        if v then v:Destroy() end
    end
    espObjs = {}

    if espOn then
        for _,plr in pairs(Players:GetPlayers()) do
            if plr ~= player and plr.Character then
                local head = plr.Character:FindFirstChild("Head")
                if head then
                    local bill = Instance.new("BillboardGui", head)
                    bill.Size = UDim2.new(0,200,0,50)
                    bill.AlwaysOnTop = true

                    local txt = Instance.new("TextLabel", bill)
                    txt.Size = UDim2.new(1,0,1,0)
                    txt.BackgroundTransparency = 1
                    txt.Text = plr.DisplayName.." (@"..plr.Name..")"
                    txt.TextColor3 = Color3.fromRGB(255,0,0)
                    txt.TextScaled = true
                    txt.Font = Enum.Font.Cartoon

                    espObjs[plr] = bill
                end
            end
        end
    end
end

-- TP MENU
local tpFrame = Instance.new("Frame", gui)
tpFrame.Size = UDim2.new(0,250,0,300)
tpFrame.Position = UDim2.new(1,-260,0.5,-150)
tpFrame.BackgroundColor3 = Color3.fromRGB(0,0,0)
tpFrame.Visible = false
Instance.new("UICorner", tpFrame)

local function refreshTP()
    tpFrame:ClearAllChildren()

    for i,plr in pairs(Players:GetPlayers()) do
        if plr ~= player then
            local btn = Instance.new("TextButton", tpFrame)
            btn.Size = UDim2.new(1,0,0,30)
            btn.Position = UDim2.new(0,0,0,(i-1)*32)
            btn.Text = plr.DisplayName.." (@"..plr.Name..")"
            btn.BackgroundColor3 = Color3.fromRGB(150,0,0)
            btn.TextScaled = true
            btn.Font = Enum.Font.Cartoon

            btn.MouseButton1Click:Connect(function()
                if plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
                    player.Character:MoveTo(plr.Character.HumanoidRootPart.Position)
                end
            end)
        end
    end
end

