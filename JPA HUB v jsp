-- FINDER
local finderFrame = Instance.new("Frame", finderTab)
finderFrame.Size = UDim2.new(1,0,1,0)
finderFrame.BackgroundTransparency = 1

local brainrots = {
    {"Nacho Spyder","50M"},
    {"Spooky and Pumpky","80M"},
    {"Ventoliero Pavonero","65M"},
    {"Rosetti Tualetti","50M"},
}

local function createFinder()
    finderFrame:ClearAllChildren()

    for i=1,5 do
        local data = brainrots[math.random(1,#brainrots)]
        local playersCount = math.random(6,8)

        local txt = Instance.new("TextLabel", finderFrame)
        txt.Size = UDim2.new(0.6,0,0,30)
        txt.Position = UDim2.new(0.05,0,0.1 + i*0.12,0)
        txt.BackgroundTransparency = 1
        txt.Text = "👥 "..playersCount.."/8 | "..data[1].." | 💰 "..data[2]
        txt.TextColor3 = Color3.fromRGB(255,255,255)
        txt.TextScaled = true
        txt.Font = Enum.Font.Cartoon

        local btn = Instance.new("TextButton", finderFrame)
        btn.Size = UDim2.new(0.25,0,0,30)
        btn.Position = UDim2.new(0.7,0,0.1 + i*0.12,0)
        btn.Text = "JOIN"
        btn.BackgroundColor3 = Color3.fromRGB(180,0,0)
        btn.TextScaled = true
        btn.Font = Enum.Font.Cartoon

        btn.MouseButton1Click:Connect(hop)
    end
end

createFinder()

